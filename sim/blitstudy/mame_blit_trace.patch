+// ikacore .blit trace hook --------------------------------------------------
+// File: 8-byte header {"BLT1", u32 version}, then per EXEC:
+//   u32 "EXEC" | u64 t_ns | u64 frame | u32 gfx_addr |
+//   u16 clip_x, clip_y, scroll_x, scroll_y | u64 mame_delay_ns |
+//   u32 nwords | u16 op_words[nwords]   (exact shadow-copy walk order)
+// All little-endian. Enabled via env CV1K_BLIT_TRACE=<path>.
+
+void cv1k_blitter_device::trace_open_if_needed()
+{
+	if (m_trace_checked)
+		return;
+	m_trace_checked = true;
+	const char *const path = std::getenv("CV1K_BLIT_TRACE");
+	if (!path)
+		return;
+	m_trace_fp = std::fopen(path, "wb");
+	if (m_trace_fp)
+	{
+		static const u8 header[8] = { 'B', 'L', 'T', '1', 1, 0, 0, 0 };
+		std::fwrite(header, 1, 8, m_trace_fp);
+	}
+}
+
+void cv1k_blitter_device::trace_exec_record()
+{
+	if (!m_trace_fp)
+		return;
+	const u32 rec_magic = 0x43455845; // "EXEC"
+	const u64 t_ns = u64(machine().time().as_double() * 1e9);
+	const u64 frame = screen().frame_number();
+	const u32 gfx_addr = m_gfx_addr;
+	const u16 regs[4] = { u16(m_gfx_clip_x_shadowcopy), u16(m_gfx_clip_y_shadowcopy),
+			u16(m_gfx_scroll_x), u16(m_gfx_scroll_y) };
+	const u64 delay_ns = m_blit_delay_ns;
+	const u32 nwords = u32(m_trace_words.size());
+	std::fwrite(&rec_magic, 4, 1, m_trace_fp);
+	std::fwrite(&t_ns, 8, 1, m_trace_fp);
+	std::fwrite(&frame, 8, 1, m_trace_fp);
+	std::fwrite(&gfx_addr, 4, 1, m_trace_fp);
+	std::fwrite(regs, 2, 4, m_trace_fp);
+	std::fwrite(&delay_ns, 8, 1, m_trace_fp);
+	std::fwrite(&nwords, 4, 1, m_trace_fp);
+	if (nwords)
+		std::fwrite(m_trace_words.data(), 2, nwords, m_trace_fp);
+	std::fflush(m_trace_fp);
+	m_trace_words.clear();
+}
+
 void cv1k_blitter_device::gfx_exec_w(address_space &space, offs_t offset, u32 data, u32 mem_mask)
 {
 	if (ACCESSING_BITS_0_7)
@@ -834,6 +888,7 @@ void cv1k_blitter_device::gfx_exec_w(address_space &space, offs_t offset, u32 da
 
 			// Create a copy of the blit list so we can safely thread it.
 			// Copying the Blitter operations will also estimate the delay needed for processing.
+			trace_open_if_needed();
 			m_blit_delay_ns = 0;
 			gfx_create_shadow_copy(space);
 
@@ -847,6 +902,8 @@ void cv1k_blitter_device::gfx_exec_w(address_space &space, offs_t offset, u32 da
 			if (m_blit_delay_ns > CV1K_FRAME_DURATION_NANOSEC)
 				LOGDBG("Blitter delay! Blit duration %lld ns.\n", m_blit_delay_ns);
 
+			trace_exec_record();
+
 			m_blitter_busy = 1;
 			m_blitter_delay_timer->adjust(attotime::from_nsec(m_blit_delay_ns));
 
diff --git a/src/mame/cave/cv1k_v.h b/src/mame/cave/cv1k_v.h
index 145332332f4..b6c919804ac 100644
--- a/src/mame/cave/cv1k_v.h
+++ b/src/mame/cave/cv1k_v.h
@@ -8,6 +8,9 @@
 
 #pragma once
 
+#include <cstdio>
+#include <vector>
+
 #define CV1K_DEBUG_VRAM_VIEWER 0 // VRAM viewer for debug
 
 class cv1k_blitter_device : public device_t, public device_video_interface
@@ -855,6 +858,18 @@ private:
 	u64 m_blit_delay_ns;
 	u16 m_blit_idle_op_bytes;
 
+	// ikacore .blit trace hook (enabled via env CV1K_BLIT_TRACE=<path>):
+	// one record per EXEC with the exact op-word stream walked by the
+	// shadow copy, written on the main thread before the blit is queued.
+	std::FILE *m_trace_fp = nullptr;
+	bool m_trace_checked = false;
+	std::vector<u16> m_trace_words;
+	void trace_open_if_needed();
+	void trace_word(u16 w) { if (m_trace_fp) m_trace_words.push_back(w); }
+	// drop the duplicate when the shadow-copy dispatch rewinds addr by one word
+	void trace_unword() { if (m_trace_fp && !m_trace_words.empty()) m_trace_words.pop_back(); }
+	void trace_exec_record();
+
 	// fpga firmware
 	std::vector<u8> m_firmware;
 	s32 m_firmware_pos;
